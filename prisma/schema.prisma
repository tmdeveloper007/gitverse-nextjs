// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum PullRequestStatus {
  OPEN
  CLOSED
  MERGED
  FAILED
}

enum DataResidencyRegion {
  US
  EU
  APAC
}

model User {
  id                      Int                  @id @default(autoincrement())
  email                   String               @unique
  passwordHash            String?              @map("password_hash") // Optional for OAuth users
  tokenVersion            Int                  @default(0) @map("token_version")
  name                    String
  emailVerified           DateTime?            @map("email_verified")
  image                   String?              @map("avatar_url")
  emailNotifications      Boolean              @default(true) @map("email_notifications")
  pushNotifications       Boolean              @default(false) @map("push_notifications")
  weeklyDigest            Boolean              @default(true) @map("weekly_digest")
  lockedUntil             DateTime?            @map("locked_until")
  failedLoginAttempts     Int                  @default(0) @map("failed_login_attempts")
  lastFailedAttemptAt     DateTime?            @map("last_failed_attempt_at")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")
  passwordChangedAt       DateTime?            @map("password_changed_at")
  repositories            Repository[]
  analysisJobs            AnalysisJob[]
  accounts                Account[]
  sessions                Session[]
  githubAccount           GitHubAccount?
  githubRepos             GitHubRepo[]
  loginAttempts           LoginAttempt[]
  aiRequestLogs           AiRequestLog[]
  organizationMemberships OrganizationMember[]
  mapAnnotations        MapAnnotation[]
  annotationActivities  AnnotationActivity[]

  @@map("users")
}

model GitHubAccount {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  githubUserId   BigInt   @unique @map("github_user_id")
  username       String   @map("username")
  accessToken    String   @map("access_token") @db.Text
  tokenEncrypted Boolean  @default(false) @map("token_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
  @@map("github_accounts")
}

model GitHubRepo {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  repoFullName   String   @map("repo_full_name")
  installationId BigInt?  @map("installation_id")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pullRequests PullRequest[]

  @@unique([userId, repoFullName])
  @@index([installationId])
  @@index([enabled])
  @@map("github_repos")
}

model PullRequest {
  id        Int               @id @default(autoincrement())
  repoId    Int               @map("repo_id")
  prNumber  Int               @map("pr_number")
  title     String
  author    String
  headSha   String            @map("head_sha")
  htmlUrl   String            @map("html_url")
  status    PullRequestStatus @default(OPEN)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  repo    GitHubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  reviews PRReview[]
  impactAnalyses PRImpactAnalysis[]

  @@unique([repoId, prNumber])
  @@index([repoId])
  @@index([headSha])
  @@map("pull_requests")
}

model PRReview {
  id            Int      @id @default(autoincrement())
  pullRequestId Int      @map("pull_request_id")
  headSha       String   @map("head_sha")
  reviewText    String   @map("review_text") @db.Text
  rawJson       Json     @map("raw_json")
  createdAt     DateTime @default(now()) @map("created_at")

  pullRequest PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@unique([pullRequestId, headSha])
  @@index([createdAt])
  @@map("pr_reviews")
}

model PRImpactAnalysis {
  id              String      @id @default(uuid()) @db.Uuid
  pullRequestId   Int         @map("pull_request_id")
  headSha         String      @map("head_sha")
  riskScore       Float?      @map("risk_score")
  impactSummary   String      @map("impact_summary") @db.Text
  breakingChanges Boolean     @default(false) @map("breaking_changes")
  aiMetrics       Json?       @map("ai_metrics")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  pullRequest     PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  @@unique([pullRequestId, headSha])
  @@index([pullRequestId])
  @@map("pr_impact_analyses")
}

model Account {
  id                String   @id @default(cuid())
  userId            Int      @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  // Index on userId for fast lookup of all accounts belonging to a user
  @@index([userId])
  // Index on provider to speed up OAuth provider-based queries (e.g. filtering by provider: "google")
  @@index([provider])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       Int      @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Repository {
  id                  Int                         @id @default(autoincrement())
  name                String
  url                 String
  description         String?
  targetDirectory     String?                     @map("target_directory")
  readmePath          String?                     @map("readme_path")
  readmeText          String?                     @map("readme_text") @db.Text
  readmeFetchedAt     DateTime?                   @map("readme_fetched_at")
  defaultBranch       String                      @default("main") @map("default_branch")
  isPrivate           Boolean                     @default(false) @map("is_private")
  inheritedRegion     DataResidencyRegion?        @map("inherited_region")
  overrideAllowed     Boolean                     @default(false) @map("override_allowed")
  stars               Int                         @default(0)
  forks               Int                         @default(0)
  size                Int                         @default(0) // Size in bytes
  lastAnalyzedAt      DateTime?                   @map("last_analyzed_at")
  status              String                      @default("pending") // pending, analyzing, completed, failed
  userId              Int                         @map("user_id")
  user                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")
  branches            Branch[]
  commits             Commit[]
  files               File[]
  contributors        Contributor[]
  languages           Language[]
  analysisJobs        AnalysisJob[]
  geminiAnalysisCache GeminiAnalysisCache[]
  securitySandboxes   SecuritySandbox[]
  reviewPolicies      ReviewPolicy[]
  policyAssignment    RepositoryPolicyAssignment?
  mapAnnotations      MapAnnotation[]
  knowledge           RepositoryKnowledge?
  syncJobs            RepositorySyncJob[]
  lastSynchronizedAt  DateTime?             @map("last_synchronized_at")

  @@index([url])
  @@index([userId])
  @@index([userId, url, targetDirectory])
  @@map("repositories")
}

model RepositorySyncJob {
  id           String    @id @default(uuid()) @db.Uuid
  repositoryId Int       @map("repository_id")
  eventType    String    @map("event_type")
  status       String    @map("status")
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message") @db.Text

  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, startedAt(sort: Desc)])
  @@index([status])
  @@map("repository_sync_jobs")
}


model AnalysisJob {
  id     String    @id @default(uuid()) @db.Uuid
  status JobStatus @default(QUEUED)
  type   String    @default("repository_analysis")

  repositoryId Int        @map("repository_id")
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  attempts    Int      @default(0)
  maxAttempts Int      @default(3) @map("max_attempts")
  nextRunAt   DateTime @default(now()) @map("next_run_at")

  progressPercent Int?    @map("progress_percent")
  progressMessage String? @map("progress_message")
  progressDetails Json?   @map("progress_details")

  lockedAt      DateTime? @map("locked_at")
  lockedBy      String?   @map("locked_by")
  lockExpiresAt DateTime? @map("lock_expires_at")

  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  error String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Worker queue: fetch next jobs to process
  @@index([status, nextRunAt])
  // Worker lock cleanup: find and release expired locks
  @@index([lockExpiresAt])
  // List all jobs for a repository sorted by newest first
  @@index([repositoryId, createdAt(sort: Desc)])
  // List all jobs for a user sorted by newest first
  @@index([userId, createdAt(sort: Desc)])
  // Filter active jobs per repository
  @@index([repositoryId, status])
}

model Branch {
  id           Int        @id @default(autoincrement())
  name         String
  isDefault    Boolean    @default(false) @map("is_default")
  isProtected  Boolean    @default(false) @map("is_protected")
  commitCount  Int        @default(0) @map("commit_count")
  lastCommitAt DateTime?  @map("last_commit_at")
  repositoryId Int        @map("repository_id")
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([repositoryId, name])
  @@map("branches")
}

model Commit {
  id           Int          @id @default(autoincrement())
  hash         String
  shortHash    String       @map("short_hash")
  message      String
  description  String?
  authorName   String       @map("author_name")
  authorEmail  String       @map("author_email")
  authorAvatar String?      @map("author_avatar")
  committedAt  DateTime     @map("committed_at")
  branch       String
  parents      String[]     @default([]) // Parent commit hashes for merge/branch tracking
  refs         String[]     @default([]) // Git ref decorations from %D (branches, remotes, HEAD -> ...)
  tags         String[]     @default([]) // Git tags associated with this commit
  additions    Int          @default(0)
  deletions    Int          @default(0)
  filesChanged Int          @default(0) @map("files_changed")
  repositoryId Int          @map("repository_id")
  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at")
  fileChanges  FileChange[]

  // Unique constraint prevents duplicate commits per repository
  @@unique([repositoryId, hash])
  // Index for fast commit listing by repository and date (most common query pattern)
  @@index([repositoryId, committedAt(sort: Desc)])
  @@map("commits")
}

model File {
  id           Int          @id @default(autoincrement())
  path         String
  name         String
  extension    String?
  size         Int          @default(0)
  language     String?
  lines        Int          @default(0)
  repositoryId Int          @map("repository_id")
  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  changes      FileChange[]

  @@unique([repositoryId, path])
  @@index([repositoryId])
  @@index([path])
  @@map("files")
}

enum AttemptType {
  LOGIN
  SIGNUP
  CHANGE_PASSWORD
  DELETE_ACCOUNT
}

enum FileChangeType {
  ADDED
  MODIFIED
  DELETED
}

model FileChange {
  id         Int            @id @default(autoincrement())
  path       String
  additions  Int            @default(0)
  deletions  Int            @default(0)
  changeType FileChangeType @map("change_type") // added, modified, deleted
  commitId   Int            @map("commit_id")
  commit     Commit         @relation(fields: [commitId], references: [id], onDelete: Cascade)
  fileId     Int?           @map("file_id")
  file       File?          @relation(fields: [fileId], references: [id], onDelete: SetNull)
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([fileId])
  @@index([commitId])
  @@map("file_changes")
}

model Contributor {
  id           Int        @id @default(autoincrement())
  name         String
  email        String
  avatar       String?
  commits      Int        @default(0)
  additions    Int        @default(0)
  deletions    Int        @default(0)
  percentage   Float      @default(0)
  firstCommit  DateTime   @map("first_commit")
  lastCommit   DateTime   @map("last_commit")
  repositoryId Int        @map("repository_id")
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([repositoryId, email])
  @@map("contributors")
}

model Language {
  id           Int        @id @default(autoincrement())
  name         String
  percentage   Float
  bytes        Int        @default(0)
  lines        Int        @default(0)
  color        String?
  repositoryId Int        @map("repository_id")
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([repositoryId, name])
  // Index for fast language lookup per repository
  @@index([repositoryId])
  @@map("languages")
}

model GeminiAnalysisCache {
  id             Int       @id @default(autoincrement())
  repositoryId   Int       @map("repository_id")
  commitHash     String    @map("commit_hash")
  analysisType   String    @map("analysis_type")
  promptHash     String    @map("prompt_hash")
  model          String?
  cachedResult   String    @map("cached_result") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  lastAccessedAt DateTime? @map("last_accessed_at")
  expiresAt      DateTime? @map("expires_at")

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, commitHash, analysisType, promptHash])
  @@index([expiresAt])
  @@index([repositoryId])
  @@map("gemini_analysis_cache")
}

model LoginAttempt {
  id        Int         @id @default(autoincrement())
  key       String
  type      AttemptType
  success   Boolean     @default(false)
  email     String?
  userId    Int?
  createdAt DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([key, type, createdAt(sort: Desc)])
  @@index([email, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("login_attempts")
}

model AiRequestLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  ip        String
  endpoint  String
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([ip, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("ai_request_logs")
}

model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  event       String
  action      String?
  payload     Json
  status      String    @default("pending") // pending, processing, completed, failed, rate_limited
  error       String?   @db.Text
  retryCount  Int       @default(0) @map("retry_count")
  maxRetries  Int       @default(3) @map("max_retries")
  nextRetryAt DateTime? @map("next_retry_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([status, nextRetryAt])
  @@map("webhook_events")
}

model SecuritySandbox {
  id             String    @id @default(uuid()) @db.Uuid
  repositoryId   Int       @map("repository_id")
  pullRequestId  Int?      @map("pull_request_id")
  headSha        String    @map("head_sha")
  status         String    @default("pending") // pending, running, completed, failed, timeout
  containerId    String?   @map("container_id") @db.Text
  imageUrl       String?   @map("image_url") @db.Text
  testResults    Json?     @map("test_results")
  exploitPayload String?   @map("exploit_payload") @db.Text
  stackTrace     String?   @map("stack_trace") @db.Text
  error          String?   @db.Text
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId, headSha])
  @@index([status])
  @@map("security_sandboxes")
}

model ReviewPolicy {
  id           Int      @id @default(autoincrement())
  repositoryId Int      @map("repository_id")
  name         String
  description  String?  @db.Text
  rules        Json // Array of { rule: string, severity: "critical"|"high"|"medium"|"low" }
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([repositoryId])
  @@map("review_policies")
}

model AiQuota {
  id               String    @id @default(uuid()) @db.Uuid
  installationId   BigInt    @unique @map("installation_id")
  requestsUsed     Int       @default(0) @map("requests_used")
  tokensConsumed   Int       @default(0) @map("tokens_consumed")
  quotaWindowStart DateTime  @default(now()) @map("quota_window_start")
  quotaWindowEnd   DateTime  @default(now()) @map("quota_window_end")
  lastAnalysisAt   DateTime? @map("last_analysis_at")
  warningPosted    Boolean   @default(false) @map("warning_posted")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([quotaWindowEnd])
  @@map("ai_quotas")
}

model RateLimit {
  id        String   @id @default(uuid()) @db.Uuid
  key       String
  points    Int      @default(0)
  expiresAt DateTime @map("expires_at")

  @@index([key])
  @@index([expiresAt])
  @@map("rate_limits")
}

model Organization {
  id                  String              @id @default(uuid()) @db.Uuid
  githubOrgId         BigInt              @unique @map("github_org_id")
  name                String
  dataResidencyRegion DataResidencyRegion @default(US) @map("data_residency_region")
  complianceMode      String              @default("STANDARD") @map("compliance_mode")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  policies     OrganizationPolicy?
  members      OrganizationMember[]
  repositories RepositoryPolicyAssignment[]

  @@map("organizations")
}

model OrganizationPolicy {
  id                     String   @id @default(uuid()) @db.Uuid
  organizationId         String   @unique @map("organization_id") @db.Uuid
  enforceSecurityReviews Boolean  @default(false) @map("enforce_security_reviews")
  enforceSecretScanning  Boolean  @default(false) @map("enforce_secret_scanning")
  blockCriticalSecrets   Boolean  @default(false) @map("block_critical_secrets")
  blackoutWindowsEnabled Boolean  @default(false) @map("blackout_windows_enabled")
  policyLockEnabled      Boolean  @default(false) @map("policy_lock_enabled")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_policies")
}

model RepositoryPolicyAssignment {
  id              String  @id @default(uuid()) @db.Uuid
  repositoryId    Int     @unique @map("repository_id")
  organizationId  String  @map("organization_id") @db.Uuid
  inheritedPolicy Boolean @default(true) @map("inherited_policy")

  enforceSecurityReviews Boolean? @map("enforce_security_reviews")
  enforceSecretScanning  Boolean? @map("enforce_secret_scanning")
  blockCriticalSecrets   Boolean? @map("block_critical_secrets")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  repository   Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("repository_policy_assignments")
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         Int      @map("user_id")
  role           String   @default("CONTRIBUTOR") // ORG_ADMIN, REPO_ADMIN, CONTRIBUTOR
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  repositoryId   Int?     @map("repository_id")
  userId         Int?     @map("user_id")
  action         String
  resource       String
  details        Json
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([repositoryId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model MapAnnotation {
  id              String               @id @default(uuid()) @db.Uuid
  repositoryId    Int                  @map("repository_id")
  authorId        Int                  @map("author_id")
  targetType      String               @map("target_type") // 'node' | 'edge'
  targetId        String               @map("target_id")
  content         String               @db.Text
  annotationType  String               @map("annotation_type") // 'comment' | 'warning' | 'technical-debt' | 'refactor' | 'documentation' | 'issue-link'
  positionX       Float?               @map("position_x")
  positionY       Float?               @map("position_y")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  repository      Repository           @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  author          User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  activities      AnnotationActivity[]

  @@index([repositoryId])
  @@index([targetId])
  @@map("map_annotations")
}

model AnnotationActivity {
  id              String        @id @default(uuid()) @db.Uuid
  annotationId    String        @map("annotation_id") @db.Uuid
  userId          Int           @map("user_id")
  action          String        // 'created' | 'updated' | 'deleted'
  details         Json?
  createdAt       DateTime      @default(now()) @map("created_at")

  annotation      MapAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([annotationId, createdAt(sort: Desc)])
  @@map("annotation_activities")
}

model RepositoryKnowledge {
  id                   Int        @id @default(autoincrement())
  repositoryId         Int        @unique @map("repository_id")
  glossary             Json?
  onboardingNotes      Json?      @map("onboarding_notes")
  architecturePrinciples Json?    @map("architecture_principles")
  projectDescription   String?    @map("project_description") @db.Text
  updatedAt            DateTime   @updatedAt @map("updated_at")

  repository           Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("repository_knowledge")
}

