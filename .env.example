
# =========================================================
# SERVER CONFIG
# =========================================================
PORT=5000

# =========================================================
# DATABASE & CONNECTION POOLING
# =========================================================
# Connection string. For serverless environments (Next.js on Vercel), use a pooled
# connection string:
#   - Neon:       use the pooled URL (contains `-pooler` in hostname)
#   - PgBouncer:  add ?pgbouncer=true to enable transaction-mode pooling
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST-pooler.region.neon.tech/neondb?sslmode=require&schema=public

# Prisma driver adapter. Options: neon-ws | neon-http | pg
#   neon-ws   WebSocket connection pooling via @prisma/adapter-neon (Recommended for serverless)
#   neon-http HTTP fetch-based driver (unpooled; lowest connection usage)
#   pg        Standard TCP pool via pg adapter (Recommended for direct/PgBouncer connections)
# Default: auto-detected (neon-ws if host is neon.tech, otherwise pg).
PRISMA_ADAPTER=neon-ws

# ── Pool Sizing ──────────────────────────────────────────
# Max connections per serverless instance.
#   Production default:  2   (prevents connection exhaustion during webhook storms)
#   Development default: 5
# Lower is safer for serverless (each instance gets its own pool).
PG_POOL_MAX=2

# Min idle connections kept in the pool. Default: 0.
# Set to 1 only if you want a warm connection ready; increases baseline connection count.
# PG_POOL_MIN=0

# Pool mode for PgBouncer compatibility.
# Set to "transaction" when using PgBouncer in transaction mode.
# This adjusts Prisma's transaction options and recommended for pooled PgBouncer setups.
# PG_POOL_MODE=transaction

# ── Timeouts ─────────────────────────────────────────────
# Connection timeout in milliseconds. Default: 30000 (30s).
# For serverless, consider lowering to 5000-10000 to fail fast during overload.
PG_POOL_CONNECTION_TIMEOUT_MS=10000

# Idle timeout in milliseconds before closing an unused connection.
#   Production default:  30000 (30s)
#   Development default: 10000 (10s)
# Lower values free connections faster during traffic spikes.
# PG_POOL_IDLE_TIMEOUT_MS=15000

# ── Retry on Transient Errors ────────────────────────────
# Maximum retry attempts for P1001/P2024/timeout errors. Default: 3.
# Set to 0 to disable retries entirely (fail fast).
PG_POOL_CONNECTION_RETRY_MAX=2

# Base backoff in ms for exponential retry (2^retry * base). Default: 500.
# Actual delays: attempt 1->1000ms, 2->2000ms, etc.
# PG_POOL_CONNECTION_RETRY_BACKOFF_MS=500

# =========================================================
# AUTHENTICATION
# =========================================================
# JWT and NEXTAUTH Secrets
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# =========================================================
# GOOGLE OAUTH
# =========================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =========================================================
# AI SERVICES
# =========================================================
GEMINI_API_KEY=your_gemini_api_key_here
AI_CHAT_RATE_LIMIT=30
AI_CHAT_WINDOW_MS=60000
AI_EXPLAIN_RATE_LIMIT=15
AI_EXPLAIN_WINDOW_MS=60000

# =========================================================
# GITHUB APP (AI PR REVIEW SYSTEM)
# =========================================================
# GitHub App (required for automatic PR reviews)
# Create a GitHub App and set:
# - Webhook URL: https://<your-web-url>/api/webhooks/github
# - Webhook secret: (match GITHUB_WEBHOOK_SECRET)
# - Permissions: pull requests (read), contents (read), issues (write) as needed
#
# Note: For GITHUB_APP_PRIVATE_KEY, you can store a multiline key with literal "\n".
# GitHub App ID (found in your GitHub App settings page)
GITHUB_APP_ID=123456
# GitHub App Private Key (download .pem from GitHub App settings, replace newlines with \n)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_APP_STATE_SECRET=

# =========================================================
# API
# =========================================================
# GitHub Actions worker trigger (required for immediate production analysis runs)
# Create a token with Actions: write on the repository that contains the worker workflow.
GITHUB_WORKFLOW_REPOSITORY=your-github-owner/your-github-repo
GITHUB_WORKFLOW_TOKEN=your-github-actions-dispatch-token
GITHUB_WORKFLOW_FILE=run-analysis-cron.yml
GITHUB_WORKFLOW_REF=main

# Internal analysis runner secret (REQUIRED in production)
# Protects /api/internal/run-analysis from unauthenticated access.
# Generate a strong random value with: openssl rand -hex 32
# The endpoint will reject ALL requests with 500 if this is not set in production.
# This secret must NEVER be passed via query string to prevent credential leakage
# in server logs, access logs, and browser history.
# Must be DIFFERENT from INTERNAL_WORKER_SECRET, CRON_SECRET, and JWT_SECRET.
ANALYSIS_RUNNER_SECRET=

# Internal worker secret (REQUIRED in production)
# Protects /api/internal/worker/webhook from unauthenticated access.
# Generate a strong random value with: openssl rand -hex 32
# Must be DIFFERENT from GITHUB_WEBHOOK_SECRET and JWT_SECRET.
# This secret is used for webhook-to-worker communication only.
INTERNAL_WORKER_SECRET=

# ========================================
# TOKEN ENCRYPTION (Production)
# ========================================
# Two modes: KMS envelope encryption (recommended) or local key encryption (fallback).
#
# ── Mode 1: KMS Envelope Encryption (Recommended) ──
# Uses AWS KMS to generate and wrap Data Encryption Keys (DEK).
# The DEK is cached in memory; the wrapped DEK can be stored in WRAPPED_DEK.
# If WRAPPED_DEK is not provided, a new DEK is generated on first use.
#
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abc123def-...
# KMS_PROVIDER=aws
# AWS_REGION=us-east-1
# WRAPPED_DEK=  # Optional: base64-encoded wrapped DEK (auto-generated if empty)
#
# Initialize KMS with: npm run kms:init
#
# ── Mode 2: Local Key Encryption (Fallback) ──
# Only used when KMS_KEY_ID is not set.
# Encrypts tokens at rest using AES-256-GCM with a static key.
#
# Generate with: openssl rand -hex 32
# Expected format: 64-character lowercase hex string
# Example: TOKEN_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
#
# Security: Never commit this value to version control.
TOKEN_ENCRYPTION_KEY=

# =========================================================
# DATABASE BACKUP
# =========================================================
# Backup target database URL. Defaults to DATABASE_URL if not set.
# Use a read-replica URL to avoid load on the primary.
# BACKUP_DATABASE_URL=

# Local backup directory (default: /tmp/db-backups)
# On Vercel serverless, /tmp is writable but ephemeral.
# Always configure S3 for production use.
# BACKUP_DIR=/tmp/db-backups

# S3 bucket for backup storage (optional, but recommended for production)
# Requires AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY to be set.
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_S3_REGION=us-east-1

# Backup retention in days (default: 7). Old backups are cleaned automatically.
# BACKUP_RETENTION_DAYS=7

# =========================================================
# CRON JOBS (Required for production)
# =========================================================
# Secret for Vercel cron job authentication.
# Generate with: openssl rand -hex 32
# Vercel injects "Authorization: Bearer <CRON_SECRET>" on each cron invocation.
CRON_SECRET=

# Optional: For client-side API calls
NEXT_PUBLIC_API_URL=http://localhost:3000

# =========================================================
# RATE LIMITING
# =========================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
# GitLab Integration
GITLAB_API_URL=https://gitlab.com/api/v4

# =========================================================
# SECURITY SANDBOX (Optional - Docker-based dynamic testing)
# =========================================================
# Enable real-time security testing via ephemeral Docker containers.
# Requires Docker to be installed and accessible on the host.
# SECURITY_SANDBOX_ENABLED=true
# DOCKER_HOST=unix:///var/run/docker.sock
