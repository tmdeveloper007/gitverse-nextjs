# Environment variables template
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require&schema=public

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# NextAuth Secret (required for NextAuth.js)
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI API Key (for AI Assistant features)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub App (required for automatic PR reviews)
# Create a GitHub App and set:
# - Webhook URL: https://<your-web-url>/api/webhooks/github
# - Webhook secret: (match GITHUB_WEBHOOK_SECRET)
# - Permissions: pull requests (read), contents (read), issues (write) as needed
#
# Note: For GITHUB_APP_PRIVATE_KEY, you can store a multiline key with literal "\n".
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Optional (defaults to NEXTAUTH_SECRET)
GITHUB_APP_STATE_SECRET=

# Optional: For client-side API calls
NEXT_PUBLIC_API_URL=http://localhost:3000


# Rate Limiting (In-Memory)
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=5   # Max attempts per window

# Email / SMTP (for password reset emails)
# Leave blank to use the dev fallback (reset link is printed to stdout instead of sent).
# Example values for Gmail with an App Password:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # Set to "true" only for port 465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="GitVerse <no-reply@gitverse.dev>"